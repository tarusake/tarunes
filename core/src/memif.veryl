interface memif::<DATA_WIDTH: u32, ADDR_WIDTH: u32> {
    var addr : logic<ADDR_WIDTH>;
    var we   : logic            ;
    var wdata: logic<DATA_WIDTH>;
    var rdata: logic<DATA_WIDTH>;

    modport master {
        addr : output,
        we   : output,
        wdata: output,
        rdata: input ,
    }

    modport slave {
        ..converse(master)
    }
}
